#include <SPI.h>
#include <nRF24L01.h>
#include <RF24.h>
// Pines ESP32
#define CE_PIN   4
#define CSN_PIN  5
#define SCK_PIN  14
#define MOSI_PIN 13
#define MISO_PIN 12
#define LED_PIN  2
RF24 radio(CE_PIN, CSN_PIN);

const byte address[6] = "ESP32";
bool switchState;
void setup() {
  pinMode(LED_PIN, OUTPUT);
  Serial.begin(115200);
  SPI.begin(SCK_PIN, MISO_PIN, MOSI_PIN, CSN_PIN);
  if (!radio.begin()) {
    Serial.println("Radio no detectada");
    while (1);
  }
  radio.setChannel(77);              
  radio.setPALevel(RF24_PA_MIN);
  radio.openReadingPipe(0, address);
  radio.startListening();
  Serial.println("ESP32 Receiver Ready");
}
