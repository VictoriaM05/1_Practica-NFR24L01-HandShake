#include <SPI.h>
#include <nRF24L01.h>
#include <RF24.h>

#define CE_PIN   4
#define CSN_PIN  5
#define SCK_PIN  14
#define MOSI_PIN 13
#define MISO_PIN 12
#define LED_PIN  2

// Se crea el objeto radio
RF24 radio(CE_PIN, CSN_PIN);

// Dirección de comunicación (debe ser la misma que el transmisor)
const byte address[6] = "ESP32";

// Variable donde se almacenará el dato recibido
bool switchState;

void setup() {

  // Configura el pin del LED como salida
  pinMode(LED_PIN, OUTPUT);

  // Inicializa la comunicación serial
  Serial.begin(115200);

  // Inicializa el bus SPI con los pines definidos
  SPI.begin(SCK_PIN, MISO_PIN, MOSI_PIN, CSN_PIN);

  // Inicializa el módulo NRF24L01
  if (!radio.begin()) {
    Serial.println("Radio no detectada");
    while (1); // Detiene el programa si no detecta el módulo
  }

  // Configura el mismo canal que el transmisor
  radio.setChannel(77);

  // Configura el nivel de potencia
  radio.setPALevel(RF24_PA_MIN);

  // Abre un canal de lectura
  radio.openReadingPipe(0, address);

  // Coloca el módulo en modo receptor
  radio.startListening();

  Serial.println("ESP32 Receiver Ready");
}

void loop() {

  // Verifica si hay datos disponibles
  if (radio.available()) {

    // Lee el dato recibido
    radio.read(&switchState, sizeof(switchState));
    Serial.print("Recibido: ");
    Serial.println(switchState);

    // Enciende o apaga el LED según el valor recibido
    digitalWrite(LED_PIN, switchState ? HIGH : LOW);
  }
}

